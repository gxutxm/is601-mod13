# Copy this file to `.env` and fill in real values.
# The app falls back to safe dev defaults if these are unset — never ship the defaults to production.

# SQLAlchemy connection string (the compose stack overrides this).
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/fastapi_calc

# JWT signing. Generate a new value with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-64-byte-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
